<?xml version="1.0" encoding="utf-8"?>
<!--
    Creative Space backup rules (API 31+).
    Collections and embers are backed up to preserve user creative work.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="collections/" />
        <include domain="file" path="embers/" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="collections/" />
        <include domain="file" path="embers/" />
    </device-transfer>
</data-extraction-rules>